# Container-side Makefile for building minimal i486 Linux
# This runs INSIDE the Docker container
#
# Targets:
#   Kernel/BusyBox: build, build-kernel, build-busybox, menuconfig-kernel, menuconfig-busybox
#   Packages:       sync-portage-configs (called automatically by build-packages.sh)
#   ISO pipeline:   initrd, rootfs, iso, all

SHELL := /bin/bash

# Directories
SRC_DIR := /src
BUILD_DIR := /build
CONFIGS_DIR := /configs
OUTPUT_DIR := /output
INITRD_DIR := /initrd

# Source directories (in build dir, synced from src dir)
KERNEL_DIR := $(BUILD_DIR)/linux-$(KERNEL_VERSION)
BUSYBOX_DIR := $(BUILD_DIR)/busybox-$(BUSYBOX_VERSION)

# Source directories in image (immutable)
KERNEL_SRC := $(SRC_DIR)/linux-$(KERNEL_VERSION)
BUSYBOX_SRC := $(SRC_DIR)/busybox-$(BUSYBOX_VERSION)

# Config files (mounted from host)
KERNEL_CONFIG := $(CONFIGS_DIR)/kernel.config
BUSYBOX_CONFIG := $(CONFIGS_DIR)/busybox.config

# Default configs (baked into image)
DEFAULT_KERNEL_CONFIG := /default-configs/kernel.config
DEFAULT_BUSYBOX_CONFIG := /default-configs/busybox.config

# Output files
KERNEL_IMAGE := $(OUTPUT_DIR)/vmlinuz
INITRD_IMAGE := $(OUTPUT_DIR)/initrd.img
SQUASHFS_IMAGE := $(OUTPUT_DIR)/rootfs.squashfs
ISO_IMAGE := $(OUTPUT_DIR)/boot.iso

.PHONY: help menuconfig-kernel menuconfig-busybox build build-kernel build-busybox \
        initrd rootfs iso all clean clean-kernel clean-busybox copy-default-configs \
        sync-sources sync-portage-configs

help:
	@echo "=========================================="
	@echo "  i486 Linux Build System (container)"
	@echo "=========================================="
	@echo ""
	@echo "Configuration:"
	@echo "  menuconfig-kernel   - Configure Linux kernel interactively"
	@echo "  menuconfig-busybox  - Configure BusyBox interactively"
	@echo "  copy-default-configs - Copy default configs to /configs"
	@echo ""
	@echo "Building:"
	@echo "  build              - Build kernel + busybox (initrd only)"
	@echo "  build-kernel       - Build kernel only"
	@echo "  build-busybox      - Build BusyBox (initrd only)"
	@echo "  initrd             - Create initramfs image"
	@echo "  rootfs             - Create SquashFS rootfs"
	@echo "  iso                - Create bootable ISO (full pipeline)"
	@echo "  all                - Alias for iso"
	@echo ""
	@echo "Portage:"
	@echo "  sync-portage-configs - Sync /configs/portage to sysroot portage dir"
	@echo ""
	@echo "Maintenance:"
	@echo "  clean              - Clean all build artifacts"
	@echo "  clean-kernel       - Clean kernel build artifacts only"
	@echo "  clean-busybox      - Clean busybox build artifacts only"
	@echo ""
	@echo "Environment:"
	@echo "  KERNEL_VERSION  = $(KERNEL_VERSION)"
	@echo "  BUSYBOX_VERSION = $(BUSYBOX_VERSION)"
	@echo "  CROSS_COMPILE   = $(CROSS_COMPILE)"

# Copy default configs to mounted volume if user wants to start fresh
copy-default-configs:
	@echo "==> Copying default configs to $(CONFIGS_DIR)"
	@if [ -f "$(DEFAULT_KERNEL_CONFIG)" ]; then \
		cp -v $(DEFAULT_KERNEL_CONFIG) $(KERNEL_CONFIG); \
	else \
		echo "Warning: No default kernel config found"; \
	fi
	@if [ -f "$(DEFAULT_BUSYBOX_CONFIG)" ]; then \
		cp -v $(DEFAULT_BUSYBOX_CONFIG) $(BUSYBOX_CONFIG); \
	else \
		echo "Warning: No default busybox config found"; \
	fi

# Sync sources from /src (in image) to /build (volume) if not present
# This enables incremental builds - object files persist between container runs
sync-sources:
	@if [ ! -d "$(KERNEL_DIR)" ]; then \
		echo "==> Syncing kernel sources to $(BUILD_DIR)..."; \
		rsync -a $(KERNEL_SRC)/ $(KERNEL_DIR)/; \
	fi
	@if [ ! -d "$(BUSYBOX_DIR)" ]; then \
		echo "==> Syncing busybox sources to $(BUILD_DIR)..."; \
		rsync -a $(BUSYBOX_SRC)/ $(BUSYBOX_DIR)/; \
	fi

# Sync runtime-mounted portage configs into the sysroot's portage directory
sync-portage-configs:
	@echo "==> Syncing portage configs to sysroot"
	@SYSROOT_PORTAGE="/usr/$(CROSS_TARGET)/etc/portage"; \
	if [ -d "$(CONFIGS_DIR)/portage" ] && [ -d "$$SYSROOT_PORTAGE" ]; then \
		cp "$(CONFIGS_DIR)/portage/make.conf" "$$SYSROOT_PORTAGE/make.conf" 2>/dev/null || true; \
		cp "$(CONFIGS_DIR)/portage/bashrc" "$$SYSROOT_PORTAGE/bashrc" 2>/dev/null || true; \
		for dir in package.use package.accept_keywords package.mask package.env env; do \
			if [ -d "$(CONFIGS_DIR)/portage/$$dir" ]; then \
				mkdir -p "$$SYSROOT_PORTAGE/$$dir"; \
				cp -r "$(CONFIGS_DIR)/portage/$$dir"/* "$$SYSROOT_PORTAGE/$$dir/" 2>/dev/null || true; \
			fi; \
		done; \
	fi

# Interactive kernel configuration
menuconfig-kernel: sync-sources
	@echo "==> Running kernel menuconfig"
	/scripts/build-kernel.sh menuconfig

# Interactive busybox configuration
menuconfig-busybox: sync-sources
	@echo "==> Running busybox menuconfig"
	/scripts/build-busybox.sh menuconfig

# Build both kernel and busybox
build: build-kernel build-busybox
	@echo "==> Build complete"

# Build kernel
build-kernel: sync-sources
	@echo "==> Building Linux kernel $(KERNEL_VERSION)"
	/scripts/build-kernel.sh build

# Build busybox
build-busybox: sync-sources
	@echo "==> Building BusyBox $(BUSYBOX_VERSION)"
	/scripts/build-busybox.sh build

# Create initramfs
initrd: build-busybox
	@echo "==> Creating initramfs"
	/scripts/build-initrd.sh

# Build root filesystem (squashfs)
rootfs:
	@echo "==> Building root filesystem"
	/scripts/build-rootfs.sh

# Create bootable ISO (full pipeline)
iso: build initrd rootfs
	@echo "==> Creating bootable ISO"
	/scripts/build-iso.sh

# Build everything
all: iso
	@echo ""
	@echo "=========================================="
	@echo "  Build Complete!"
	@echo "=========================================="
	@echo "  Kernel:  $(KERNEL_IMAGE)"
	@echo "  Initrd:  $(INITRD_IMAGE)"
	@echo "  ISO:     $(ISO_IMAGE)"
	@echo ""
	@echo "Test with: qemu-system-i386 -cdrom $(ISO_IMAGE)"

# Clean kernel build artifacts only
clean-kernel:
	@echo "==> Cleaning kernel build artifacts"
	@if [ -d "$(KERNEL_DIR)" ]; then \
		cd $(KERNEL_DIR) && make ARCH=i386 clean; \
	fi

# Clean busybox build artifacts only
clean-busybox:
	@echo "==> Cleaning busybox build artifacts"
	@if [ -d "$(BUSYBOX_DIR)" ]; then \
		cd $(BUSYBOX_DIR) && make clean; \
	fi

# Clean all build artifacts
clean: clean-kernel clean-busybox
	@echo "==> Cleaning output artifacts"
	rm -rf $(INITRD_DIR)/*
	rm -f $(OUTPUT_DIR)/*
