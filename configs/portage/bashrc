# Portage bashrc for cross-compilation environment
#
# Sourced by Portage at the start of each ebuild phase.
# $EBUILD_PHASE contains the current phase name.

# Fix libtool stripping -static from LDFLAGS.
#
# Libtool intercepts -static and "prefers" static archives but does NOT
# pass -static to the compiler — so the binary still uses the dynamic CRT
# and interpreter. The -all-static flag does pass -static, but it's a
# libtool-only flag that breaks configure tests if placed in LDFLAGS.
#
# Solution: after configure generates the libtool script, sed-patch it so
# the -static handler also passes $link_static_flag to the compiler
# (matching -all-static behavior). Runs unconditionally — if no libtool
# script exists in WORKDIR (e.g. cmake/meson packages) the find returns
# nothing and the loop is a no-op.
if [[ ${EBUILD_PHASE} == "configure" ]]; then
	post_src_configure() {
		local lt
		while IFS= read -r -d '' lt; do
			einfo "Patching libtool for full static linking: ${lt}"
			sed -i 's/prefer_static_libs=built/prefer_static_libs=built\n\tcompile_command="$compile_command $link_static_flag"\n\tfinalize_command="$finalize_command $link_static_flag"/' "${lt}"
		done < <(find "${WORKDIR}" -name libtool -type f -print0 2>/dev/null)
	}

fi

# nethack: makedefs/lev_comp/dgn_comp/dlb are compiled for i486 (the target)
# but immediately executed on the x86_64 build host to generate source files.
# This is the classic "build tool" cross-compilation problem.
#
# Fix: use Python to patch util/Makefile (generated by configure from
# sys/unix/Makefile.utl) before compilation:
#   1. Set OBJDIR = . so host-tool .o files land in util/, not src/.
#      Without this, makedefs links against already-built i486 ../src/monst.o
#      and ../src/objects.o, producing an i486 binary that can't run on x86_64.
#   2. Insert CC_FOR_BUILD/CFLAGS_FOR_BUILD variable defaults.
#   3. Use 'override' target-specific vars for makedefs/lev_comp/dgn_comp/dlb.
#      'override' is required because the ebuild calls make with CC= and CFLAGS=
#      on the command line, which normally beats target-specific assignments.
#      Target-specific vars propagate to prerequisites, so ./monst.o and
#      ./objects.o (with OBJDIR=.) will also compile with the host gcc.
if [[ ${EBUILD_PHASE} == "compile" ]]; then
	pre_src_compile() {
		[[ ${CATEGORY}/${PN} == "games-roguelike/nethack" ]] || return 0

		# configure copies sys/unix/Makefile.utl → util/Makefile; patch the copy
		local makefile="${S}/util/Makefile"
		[[ -f "${makefile}" ]] || return 0

		einfo "nethack: patching util/Makefile for CC_FOR_BUILD cross-compilation"

		# vis_tab.h and vis_tab.c ship pre-generated in the tarball, so make
		# considers them up-to-date and skips 'makedefs -v'. Delete them to
		# force makedefs -v to regenerate them for the current build.
		rm -f "${S}/include/vis_tab.h" "${S}/src/vis_tab.c"

		python3 - "${makefile}" <<'PYEOF'
import re, sys
f = sys.argv[1]
content = open(f).read()

# 1. Change OBJDIR = ../src to OBJDIR = .
content = re.sub(r'^OBJDIR\s*=\s*\.\./src', 'OBJDIR = .', content, flags=re.MULTILINE)

# 2. Insert CC_FOR_BUILD block after the LFLAGS definition line.
#    'override' beats command-line CC=/CFLAGS=/LFLAGS= passed by the ebuild.
insert = """
# Cross-compilation: build host tools with the native compiler.
# 'override' is required to beat the command-line CC=/CFLAGS=/LFLAGS= set by the ebuild.
# Target-specific vars propagate to prerequisites (makedefs.o, ./monst.o, etc.)
CC_FOR_BUILD ?= gcc
CFLAGS_FOR_BUILD ?= -O2 -std=gnu89 -I../include -DDLB -DSECURE -DTIMED_DELAY -DVISION_TABLES -DDUMPLOG -DSCORE_ON_BOTL

makedefs lev_comp dgn_comp dlb: override CC := $(CC_FOR_BUILD)
makedefs lev_comp dgn_comp dlb: override CFLAGS := $(CFLAGS_FOR_BUILD)
makedefs lev_comp dgn_comp dlb: override LFLAGS :=
"""

# Append to end of file — util/Makefile doesn't define LFLAGS as a variable
# (it's only passed on the command line), so anchoring on LFLAGS would miss.
content += insert

open(f, 'w').write(content)
print("nethack: util/Makefile patched OK")
PYEOF

		einfo "nethack: util/Makefile patched successfully"
	}
fi

# mandoc: pkg_postinst calls 'makewhatis || die' but makewhatis is an i486 binary
# that cannot run on the x86_64 build host. Override pkg_postinst to use the
# host's native makewhatis (installed via Dockerfile) to build the whatis database
# against the sysroot's man pages at build time.
# Bashrc is sourced after the ebuild is loaded, so this definition wins.
if [[ ${EBUILD_PHASE} == "postinst" ]] && [[ ${CATEGORY}/${PN} == "app-text/mandoc" ]]; then
	pkg_postinst() {
		local host_makewhatis="/usr/sbin/makewhatis"
		if [[ -x "${host_makewhatis}" ]]; then
			einfo "mandoc: building whatis database with host makewhatis"
			"${host_makewhatis}" "${ROOT}/usr/share/man" || true
		else
			ewarn "mandoc: host makewhatis not found; whatis database not built"
			ewarn "Rebuild the Docker image to install app-text/mandoc on the host."
		fi
	}
fi
