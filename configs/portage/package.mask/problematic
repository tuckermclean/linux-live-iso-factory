# Mask problematic package versions
#
# Some versions may have issues with cross-compilation,
# static linking, or musl compatibility.
# Add them here to prevent emerge from selecting them.

# Example:
# Block specific broken versions
# =net-misc/curl-8.0.0
# =app-shells/bash-5.2_p15

# Block entire version ranges
# >=dev-lang/lua-5.5

# man-db pulls virtual/tmpfiles → systemd-utils[tmpfiles] which has a hard
# REQUIRED_USE on PYTHON_SINGLE_TARGET. Mask it so virtual/man resolves to
# app-text/mandoc instead.
sys-apps/man-db

# fortune-mod CMake requires a pre-installed native 'strfile' binary in PATH.
# Cross-compiling this is a circular build-tool dependency.
# Re-enable by installing fortune-mod natively in the Dockerfile first.
games-misc/fortune-mod

# nmap has an unconditional REQUIRED_USE on python_single_target even when all
# Python features (ndiff, zenmap, nse) are disabled — pulls in full Python runtime.
# Re-enable by adding dev-lang/python to world and setting python_single_target_python3_12
# in package.use/nmap.
net-analyzer/nmap

# irssi → glib needs libatomic; cross-gcc only has libatomic.so (no libatomic.a).
# Fix: verify static-libs was correctly applied to the cross-gcc package and
# that libatomic.a exists at /usr/lib/gcc/i486-linux-musl/<ver>/libatomic.a.
# Check with: make shell → ls /usr/lib/gcc/i486-linux-musl/*/libatomic*
net-irc/irssi
