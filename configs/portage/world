# Gentoo world file for i486-linux-musl cross-compiled packages
#
# Standard Gentoo format: one atom per line
# These packages will be built statically for the minimal Linux system
#
# Add packages here and run: make build-packages

# Shell - real bash instead of busybox sh
app-shells/bash

# Remote access
net-misc/dropbear

# Network utilities
net-misc/curl

# Text editors
app-editors/nano

# Compression utilities (real implementations vs busybox)
app-arch/xz-utils
app-arch/bzip2
app-arch/gzip

# Scripting language - lightweight and embeddable
dev-lang/lua

# File utilities
sys-apps/file
sys-apps/less

# Init system (replaces BusyBox init)
sys-apps/sysvinit

# Core GNU userland (replaces BusyBox applets)
sys-apps/coreutils
sys-apps/util-linux
sys-apps/findutils
sys-apps/grep
sys-apps/sed
sys-apps/gawk
app-arch/tar
sys-process/procps

# Networking (replaces BusyBox udhcpc/ifconfig)
sys-apps/iproute2
net-misc/iputils
net-misc/dhcpcd
