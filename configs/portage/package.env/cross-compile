# Per-package environment overrides for cross-compilation
#
# Format: category/package environment-file.conf
#
# Environment files are stored in the portage env/ directory

# Force static, non-PIE linking for all leaf binaries.
# static.conf adds -static to LDFLAGS, disables PIE (which conflicts with
# static linking on i486/musl), and passes --disable-shared to libtool.

app-shells/bash       static.conf
net-misc/dropbear     static.conf
net-misc/curl         static.conf
app-editors/nano      static.conf
app-arch/xz-utils     static.conf
app-arch/bzip2        static.conf
app-arch/gzip         static.conf
dev-lang/lua          static.conf
dev-libs/openssl      static.conf
sys-apps/file         static.conf
sys-apps/less         static.conf
